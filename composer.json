{
    "name": "shashe-egovernment/rest-api",
    "description": "REST API layer for Shashe E-Government System",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "eris/eris": "^0.14"
    },
    "autoload": {
        "psr-4": {
            "ShasheEGov\\Api\\": "api/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}